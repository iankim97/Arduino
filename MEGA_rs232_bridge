#include <Wire.h>
#include <LiquidCrystal_I2C.h>

// LCD 주소 설정 (0x27 또는 0x3F)
LiquidCrystal_I2C lcd(0x27, 16, 2); 

void setup() {
  // 1. 모든 시리얼 포트 초기화
  Serial.begin(115200);   // PC 모니터링용
  Serial1.begin(9600);    // RXTX#2 전송용
  Serial2.begin(9600);    // 바코드 리더기용
  
  // 2. LCD 초기화
  lcd.init();
  lcd.backlight();
  lcd.setCursor(0, 0);
  lcd.print("SYSTEM READY");
  lcd.setCursor(0, 1);
  lcd.print("Waiting Scan...");
  
  Serial.println("--- BARCODE HOLD SYSTEM ONLINE ---");
}

void loop() {
  // Serial2(리더기)에서 데이터가 감지될 때만 실행
  if (Serial2.available()) {
    delay(100); // 전체 데이터 수신 대기
    String barcode = Serial2.readStringUntil('\n'); 
    barcode.trim(); 

    if (barcode.length() > 0) {
      // [1] 시리얼 모니터 출력
      Serial.print("Last Scan: ");
      Serial.println(barcode);
      
      // [2] LCD 갱신 (다음 스캔 전까지 이 값이 유지됩니다)
      lcd.clear();
      lcd.setCursor(0, 0);
      lcd.print("Last Scanned:");
      lcd.setCursor(0, 1);
      lcd.print("                "); // 이전 잔상 제거용 공백
      lcd.setCursor(0, 1);
      lcd.print(barcode); 
      
      // [3] RXTX#2(Serial1)로 데이터 즉시 전송
      Serial1.println(barcode); 
      Serial.println("Forwarded to RXTX#2");
    }
  }
}
